# =============================================================================
# Craftwell Health Adviser — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# See docs/setup.md for full details.
# =============================================================================

# -----------------------------------------------------------------------------
# Required (Core) — needed for every page
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# Required (AI / Backend routes) — needed by chat, search, and ingestion APIs
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=craftwell
VOYAGE_API_KEY=your-voyage-ai-api-key

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=your-youtube-data-api-key
ADMIN_API_KEY=your-admin-bearer-token
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug
